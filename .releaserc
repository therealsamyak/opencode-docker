{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "echo $DOCKER_PASSWORD | docker login $REGISTRY -u $DOCKER_USERNAME --password-stdin",
        "publishCmd": "docker buildx build --platform linux/amd64,linux/arm64 --push -t $REGISTRY/$IMAGE_NAME:${nextRelease.version} -t $REGISTRY/$IMAGE_NAME:latest --cache-from type=gha --cache-to type=gha,mode=max --label org.opencontainers.image.version=${nextRelease.version} ."
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": []
      }
    ]
  ]
}
